# ============================================
# DeFi Sentinel — Environment Configuration
# ============================================

# Casper Network
CASPER_NODE_URL=https://rpc.testnet.casperlabs.io

# CSPR.cloud API (get key at https://cspr.build)
CSPR_CLOUD_API_KEY=your_cspr_cloud_key_here

# Agent Wallet (Testnet only!)
AGENT_PRIVATE_KEY=your_testnet_wallet_private_key

# Sentinel Smart Contract (fill after deploy)
SENTINEL_CONTRACT_HASH=will_be_filled_after_deploy

# Anthropic Claude API (Week 2)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Risk Engine
RISK_THRESHOLD=70
POLL_INTERVAL_SECONDS=60

# Wallet to monitor
WATCHED_WALLET=your_testnet_wallet_address
