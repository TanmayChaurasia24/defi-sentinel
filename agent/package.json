{
  "name": "defi-sentinel-agent",
  "version": "0.2.0",
  "description": "Autonomous AI agent for on-chain DeFi risk monitoring on Casper Network",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --config jest.config.js",
    "lint": "tsc --noEmit",
    "server": "ts-node src/server.ts",
    "deploy-contract": "ts-node scripts/deployContract.ts",
    "dev:all": "concurrently \"npm run dev\" \"cd ../dashboard && npm run dev\""
  },
  "keywords": [
    "casper",
    "defi",
    "ai-agent",
    "risk-monitoring",
    "blockchain",
    "claude",
    "x402"
  ],
  "author": "DeFi Sentinel Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "casper-js-sdk": "^2.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  }
}
