# ============================================
# DeFi Sentinel Agent — Environment Variables
# ============================================

# Casper Testnet RPC endpoint
CASPER_NODE_URL=https://rpc.testnet.casperlabs.io

# CSPR.cloud API key (register at https://cspr.build)
CSPR_CLOUD_API_KEY=your_cspr_cloud_key_here

# Agent wallet private key (TESTNET ONLY — never use mainnet keys!)
AGENT_PRIVATE_KEY=your_testnet_wallet_private_key

# Sentinel contract hash (fill after deploying the contract)
SENTINEL_CONTRACT_HASH=will_be_filled_after_deploy

# OpenRouter API key (free tier — get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter model to use (free models available)
# Options: deepseek/deepseek-chat-v3-0324:free, google/gemini-2.0-flash-exp:free, meta-llama/llama-4-maverick:free
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# Risk scoring threshold (0-100). Scores above this trigger rebalance.
RISK_THRESHOLD=70

# How often to poll wallet data (in seconds)
POLL_INTERVAL_SECONDS=60

# The Casper Testnet wallet address to monitor
WATCHED_WALLET=your_testnet_wallet_address

# MCP Server URL (local Casper MCP server)
MCP_SERVER_URL=http://localhost:3000

# ============================================
# Micropayments & Extra Settings
# ============================================

# x402 micropayment facilitator URL
X402_FACILITATOR_URL=https://x402.cspr.cloud

# x402 agent wallet for micropayments
X402_AGENT_WALLET=your_x402_micropayment_wallet_address

# x402 agent wallet private key
X402_AGENT_PRIVATE_KEY=your_x402_wallet_private_key

# CSPR.click API URL
CSPR_CLICK_API_URL=https://api.cspr.click

# Maximum CSPR amount per rebalance transaction
REBALANCE_AMOUNT_CSPR=50

# Dashboard API server port
DASHBOARD_API_PORT=4000
